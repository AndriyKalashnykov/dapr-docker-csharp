# Environment defaults for dapr-docker-csharp.
#
# `docker compose` auto-loads `.env` in the project directory; `.env.example`
# is the committed source of truth. Copy to `.env` for local overrides
# (`.env` is gitignored). The Makefile and e2e harness read the same vars
# via `?=` and `${VAR:-default}` forms so all three call paths stay in sync.

# Host-side port mapping for the queueprocessor service.
# Override per-run for parallel-safe e2e (the e2e harness allocates an ephemeral
# value via scripts/pick-port.sh).
HOST_PORT=5000

# Host-side port mapping for Redis (only used when `make start` exposes Redis
# for `redis-cli`-from-host debugging). E2E drops this binding entirely via
# e2e/docker-compose.e2e.override.yaml.
REDIS_HOST_PORT=6379

# Container-internal app port — must match what the binary binds to.
# Used by ASPNETCORE_URLS, the daprd `--app-port` flag, and the compose-level
# healthcheck URL inside the queueprocessor container.
APP_INTERNAL_PORT=5000

# OpenTelemetry OTLP exporter (gRPC). Leave empty to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=queueprocessor

# Hosts. APP_HOST is the external-facing hostname (host machine, ingress, etc.);
# DAPR_HOST is the in-pod sidecar hostname (always loopback when the sidecar
# shares the app's network namespace via Docker `network_mode: service:…`).
# HEALTHCHECK_HOST is the in-container self-probe target.
APP_HOST=localhost
DAPR_HOST=localhost
HEALTHCHECK_HOST=localhost

# Dapr defaults — used by Makefile dapr-* targets, the e2e harness, and the
# integration-test fixture's Testcontainers daprd container.
DAPR_HTTP_PORT=3500
DAPR_GRPC_PORT=50001
PUBSUB_NAME=pubsub
TOPIC_NAME=counter

# Jaeger query API — used by e2e to verify trace ingestion.
JAEGER_HOST=jaeger
JAEGER_QUERY_PORT=16686

# Host-side Jaeger port mappings (only used in dev `make start`; e2e drops
# these via the override file). All three default to Jaeger's container-internal
# contract — parameterize per-run if collisions are likely.
JAEGER_QUERY_HOST_PORT=16686
JAEGER_OTLP_GRPC_HOST_PORT=4317
JAEGER_OTLP_HTTP_HOST_PORT=4318

# Dockerfile HEALTHCHECK tunables — applied at image build via --build-arg.
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=3s
HEALTHCHECK_START_PERIOD=20s
HEALTHCHECK_RETRIES=3

# Compose-level healthcheck tunables (dev compose stack only).
COMPOSE_HEALTHCHECK_INTERVAL=10s
COMPOSE_HEALTHCHECK_TIMEOUT=3s
COMPOSE_HEALTHCHECK_RETRIES=30
COMPOSE_HEALTHCHECK_START_PERIOD=60s

# E2E harness tunables (seconds unless noted).
E2E_READINESS_TIMEOUT_SECONDS=120
E2E_PUBSUB_POLL_SECONDS=30
E2E_JAEGER_POLL_SECONDS=30
E2E_CURL_MAX_TIME_SECONDS=5
E2E_PROBE_MAX_TIME_SECONDS=2
E2E_POLL_INTERVAL_SECONDS=1

# act-runner ephemeral artifact-server port range (used by `make ci-run`).
ACT_PORT_MIN=40000
ACT_PORT_MAX=59999
