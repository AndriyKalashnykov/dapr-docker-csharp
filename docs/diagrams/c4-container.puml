@startuml c4-container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.13.0/C4_Container.puml

LAYOUT_LEFT_RIGHT()

' Modern flat styling: no shadows, sharp corners, clean sans-serif, modern palette.
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam roundCorner 4
skinparam defaultFontName "Inter, Helvetica, Arial, sans-serif"
skinparam defaultFontSize 13
skinparam ArrowColor #37474F
skinparam ArrowThickness 1.2
skinparam rectangleBorderThickness 1.3

UpdateElementStyle("person", $fontColor="#FFFFFF", $bgColor="#0F766E", $borderColor="#134E4A")
UpdateElementStyle("container", $fontColor="#FFFFFF", $bgColor="#2563EB", $borderColor="#1E3A8A")
UpdateBoundaryStyle($bgColor="#F1F5F9", $borderColor="#94A3B8", $fontColor="#1E293B")

' ContainerDb() shares the plain `container` tag (there is NO distinct DB tag in
' C4-PlantUML), so a custom tag attached at the call site via $tags is the only
' way to colour the datastore violet. `container_db` in UpdateElementStyle no-ops.
AddElementTag("datastore", $fontColor="#FFFFFF", $bgColor="#7C3AED", $borderColor="#4C1D95")

title Container Diagram — QueueProcessor on Docker Compose

Person(operator, "Operator", "Publishes messages and inspects processed state")

System_Boundary(compose, "Docker Compose Stack") {
  Container(app, "QueueProcessor", "C# / .NET 10 · ASP.NET Core · Dapr.AspNetCore 1.18", "Exposes the counter API (GET state, POST /counter) and subscribes to the 'counter' pub/sub topic")
  Container(daprd, "Dapr Sidecar", "daprd 1.18.1", "Provides the pub/sub and state-store building blocks · HTTP 3500 · gRPC 50001")
  ContainerDb(redis, "Redis", "redis:8", "Backs the state store and the pub/sub broker (Redis Streams)", $tags="datastore")
  Container(jaeger, "Jaeger", "jaegertracing/jaeger 2.19.0", "Collects OpenTelemetry traces · UI on port 16686")
}

Rel(operator, app, "Sends requests to", "HTTP · port 5000")
Rel(app, daprd, "Invokes building blocks via", "HTTP / gRPC · shared loopback")
Rel(daprd, redis, "Persists and streams data over", "RESP")
Rel(app, jaeger, "Exports traces to", "OTLP / gRPC · port 4317")
Rel(daprd, jaeger, "Exports traces to", "OTLP / gRPC · port 4317")

SHOW_LEGEND()
@enduml
